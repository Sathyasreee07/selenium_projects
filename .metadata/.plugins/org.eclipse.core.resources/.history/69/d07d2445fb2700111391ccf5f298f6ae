package com.orangehrm.sleniumuiframework.object_repository;

import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.Keys;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.FindBy;
import org.openqa.selenium.support.PageFactory;

public class CandidatePage {
	public CandidatePage(WebDriver driver) {
		PageFactory.initElements(driver, this);
	}
	
	
	@FindBy(xpath = "//label[text()='Job Title']/../..//div[@class='oxd-select-wrapper']")
	private WebElement jobTitleDropDown;
	
	@FindBy(xpath = "//label[text()='Hiring Manager']/../..//div[@class='oxd-select-wrapper']")
	private WebElement hiringManagerDropDown;
	
	@FindBy(xpath = "//label[text()='Vacancy']/../..//div[@class='oxd-select-wrapper']")
	private WebElement vacancyDropDown;

	@FindBy(xpath = "//label[text()='Status']/../..//div[@class='oxd-select-wrapper']")
	private WebElement statusDropDown;

	
	@FindBy(xpath = "//input[@placeholder='Type for hints...']")
	private WebElement candidateName;
	
	@FindBy(xpath = "//label[.='Date of Application']/../..//input")
	private WebElement date;
	
	@FindBy(css = "[class='oxd-button oxd-button--medium oxd-button--secondary orangehrm-left-space']")
	private WebElement SaveBtn;
	
	@FindBy(xpath = "//div[@class='orangehrm-horizontal-padding orangehrm-vertical-padding']//span")
	private WebElement record;
	
	@FindBy(xpath = "//div[@role='row']//div[@role='cell'][3]")
	private List<WebElement> candidateNames;

	public List<WebElement> getCandidateNameList() {
	    return candidateNames;
	}
	
	
	

	public WebElement getJobTitleDropDown() {
		return jobTitleDropDown;
	}


	public WebElement getHiringManagerDropDown() {
		return hiringManagerDropDown;
	}


	public WebElement getVacancyDropDown() {
		return vacancyDropDown;
	}

	public WebElement getStatusDropDown() {
		return statusDropDown;
	}


	public WebElement getCandidateName() {
		return empName;
	}


	public void setCandidateName(String empName) {
		getCandidateName().sendKeys(empName);
	}


	public WebElement getDate() {
		return date;
	}


	public void setDate(String date) {
		getDate().sendKeys(date);
	}


	public WebElement getSaveBtn() {
		return SaveBtn;
	}


	public void clcikSaveBtn() {
		getSaveBtn().click();
	}


	public WebElement getRecord() {
		return record;
	}


	

	
	
	
	


}
